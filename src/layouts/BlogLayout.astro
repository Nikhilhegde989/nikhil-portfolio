---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  currentPath?: string;
}

const {
  title,
  description,
  ogImage,
  type = 'website',
  publishedAt,
  currentPath = '',
} = Astro.props;

const siteUrl = 'https://nikhilhegde.com';
const fullTitle = `${title} — Nikhil Hegde`;
const isPost = currentPath.startsWith('/blog/') && currentPath !== '/blog/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}

    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Nikhil Hegde" />
    {ogImage && <meta property="og:image" content={`${siteUrl}${ogImage}`} />}
    {publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
    {publishedAt && <meta property="article:author" content="Nikhil Hegde" />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}

    <link rel="canonical" href={`${siteUrl}${currentPath}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CYL1PSW02D"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-CYL1PSW02D');
    </script>
  </head>

  <body class="bg-[#07070f] text-white min-h-screen antialiased">
    <nav class="fixed top-0 left-0 right-0 bg-[#07070f]/90 backdrop-blur-md border-b border-white/[0.06] z-50">
      <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="text-xl font-bold text-white tracking-tight hover:text-emerald-400 transition-colors">
            NH<span class="text-emerald-500">.</span>
          </a>
          <div class="flex items-center gap-7">
            <a href="/" class="text-slate-400 hover:text-white text-sm font-medium transition-colors">
              Portfolio
            </a>
            <a
              href="/blog"
              class={`text-sm font-medium transition-colors ${isPost ? 'text-slate-400 hover:text-white' : 'text-white'}`}
            >
              Writing
            </a>
            {isPost && (
              <a
                href="#"
                id="back-to-top"
                class="text-slate-500 hover:text-white text-sm transition-colors hidden md:block"
              >
                ↑ Top
              </a>
            )}
          </div>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="border-t border-white/[0.06] py-10 mt-20">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-slate-600 text-sm">© 2025 Nikhil Hegde. All rights reserved.</p>
        <div class="flex items-center gap-6">
          <a
            href="https://github.com/Nikhilhegde989"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-white transition-colors text-sm"
          >GitHub</a>
          <a
            href="https://www.linkedin.com/in/nikhilhegde989/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-600 hover:text-white transition-colors text-sm"
          >LinkedIn</a>
          <a href="/" class="text-slate-600 hover:text-white transition-colors text-sm">Portfolio</a>
          <a href="/blog" class="text-slate-600 hover:text-white transition-colors text-sm">Writing</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const backBtn = document.getElementById('back-to-top');
      if (backBtn) {
        backBtn.addEventListener('click', (e) => {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
